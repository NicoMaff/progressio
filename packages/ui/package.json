{
  "name": "@progressio/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "exports": {
    ".": "./src/index.ts",
    "./atoms": "./src/components/atoms/index.ts",
    "./components": "./src/components/index.ts",
    "./molecules": "./src/components/molecules/index.ts",
    "./organisms": "./src/components/organisms/index.ts",
    "./components/atoms": "./src/components/atoms/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./atoms/*": "./src/components/atoms/*.tsx",
    "./components/atoms/*": "./src/components/atoms/*.tsx",
    "./components/molecules": "./src/components/molecules/index.ts",
    "./components/molecules/*": "./src/components/molecules/*.tsx",
    "./components/organisms": "./src/components/organisms/index.ts",
    "./components/organisms/*": "./src/components/organisms/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./molecules/*": "./src/components/molecules/*.tsx",
    "./organisms/*": "./src/components/organisms/*.tsx",
    "./styles.css": "./src/styles.css"
  },
  "imports": {
    "#atoms/*": "./src/components/atoms/*.tsx",
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts",
    "#molecules/*": "./src/components/molecules/*.tsx",
    "#organisms/*": "./src/components/organisms/*.tsx",
    "#ui/*": "./src/components/atoms/*.tsx"
  },
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "lint": "yarn run -T eslint . --config ../../eslint.config.mjs",
    "format": "yarn run -T prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "yarn run -T prettier --check . --ignore-path ../../.prettierignore",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests configured for @progressio/ui yet\""
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",
    "@fontsource/public-sans": "^5.2.7",
    "class-variance-authority": "^0.7.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/react-vite": "^10.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "catalog:",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.5.2",
    "typescript": "^6.0.3",
    "vite": "catalog:"
  }
}
