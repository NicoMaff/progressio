{
  "name": "@progressio/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "exports": {
    ".": "./src/index.ts",
    "./atoms": "./src/components/atoms/index.ts",
    "./components": "./src/components/index.ts",
    "./molecules": "./src/components/molecules/index.ts",
    "./components/atoms": "./src/components/atoms/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./atoms/*": "./src/components/atoms/*.tsx",
    "./components/atoms/*": "./src/components/atoms/*.tsx",
    "./components/molecules": "./src/components/molecules/index.ts",
    "./components/molecules/*": "./src/components/molecules/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./molecules/*": "./src/components/molecules/*.tsx",
    "./styles.css": "./src/styles.css"
  },
  "imports": {
    "#atoms/*": "./src/components/atoms/*.tsx",
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts",
    "#molecules/*": "./src/components/molecules/*.tsx",
    "#ui/*": "./src/components/atoms/*.tsx"
  },
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "lint": "yarn run -T eslint . --config ../../eslint.config.mjs",
    "format": "yarn run -T prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "yarn run -T prettier --check . --ignore-path ../../.prettierignore",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests configured for @progressio/ui yet\""
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "react-hook-form": "^7.81.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "catalog:",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vite": "catalog:"
  }
}
