{
  "name": "@progressio/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "refresh:demo-work-file": "node ace dev:refresh-work-file",
    "test": "node ace test",
    "lint": "yarn run -T eslint . --config ../../eslint.config.mjs",
    "format": "yarn run -T prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "yarn run -T prettier --check . --ignore-path ../../.prettierignore",
    "typecheck": "tsc --noEmit && tsc --noEmit --project inertia/tsconfig.json"
  },
  "imports": {
    "#controllers/*": "./src/controllers/*.js",
    "#exceptions/*": "./src/core/exceptions/*.js",
    "#models/*": "./src/core/models/*.js",
    "#mails/*": "./src/mails/*.js",
    "#services/*": "./src/services/*.js",
    "#listeners/*": "./src/core/listeners/*.js",
    "#events/*": "./src/events/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#src/*": "./src/*.js",
    "#middleware/*": "./src/core/middleware/*.js",
    "#middlewares/*": "./src/core/middleware/*.js",
    "#transformers/*": "./src/transformers/*.js",
    "#teaching_content/*": "./src/teaching_content/*.js",
    "#validators/*": "./src/validators/*.js",
    "#providers/*": "./src/core/providers/*.js",
    "#policies/*": "./src/core/policies/*.js",
    "#abilities/*": "./src/core/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.2.0",
    "@japa/browser-client": "^2.3.0",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "youch": "^4.1.1"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.1.0",
    "@adonisjs/core": "^7.3.5",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/inertia": "^4.2.0",
    "@adonisjs/lucid": "^22.4.2",
    "@adonisjs/session": "^8.1.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.1",
    "@adonisjs/vite": "^5.1.1",
    "@inertiajs/react": "^2.3.27",
    "@progressio/ui": "workspace:*",
    "@tuyau/core": "^1.2.2",
    "@vinejs/vine": "^4.4.0",
    "better-sqlite3": "^12.11.1",
    "edge.js": "^6.5.1",
    "luxon": "^3.7.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "sonner": "^2.0.7"
  },
  "hotHook": {
    "boundaries": [
      "./src/**/controllers/**/*.ts",
      "./src/core/middleware/*.ts"
    ]
  }
}
