{
  "arrowParens": "always",
  "bracketSpacing": true,
  "plugins": ["prettier-plugin-tailwindcss"],
  "printWidth": 120,
  "quoteProps": "consistent",
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "tailwindFunctions": ["clsx", "cva", "cx"],
  "trailingComma": "es5",
  "useTabs": false
}
